@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "Usuário" as Usuario
actor "Administrador" as Admin
actor "Dono do Protocolo" as Dono

Admin --|> Usuario
Dono --|> Usuario

rectangle "AutoPlan - Sistema de Simulação e Gestão de Protocolos" {
  usecase "Autenticar-se" as UC_Login
  usecase "Encerrar sessão" as UC_Logout
  usecase "Criar simulação" as UC_Simular
  usecase "Gerar protocolo" as UC_Gerar
  usecase "Listar protocolos" as UC_Listar
  usecase "Visualizar detalhe\ndo protocolo" as UC_Detalhar
  usecase "Atualizar status\nde pagamento" as UC_Atualizar
  usecase "Registrar novo usuário" as UC_Registrar
  usecase "Configurar regras\nde pagamento" as UC_Regras
}

Usuario --> UC_Login
Usuario --> UC_Logout
Usuario --> UC_Simular
Usuario --> UC_Listar
Usuario --> UC_Detalhar

Admin --> UC_Registrar
Admin --> UC_Regras

Dono --> UC_Atualizar

UC_Simular ..> UC_Gerar : <<include>>
UC_Detalhar ..> UC_Listar : <<extend>>
UC_Atualizar ..> UC_Detalhar : <<extend>>

@enduml
